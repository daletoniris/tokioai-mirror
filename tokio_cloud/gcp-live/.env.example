# ═══════════════════════════════════════════════════════════
# TokioAI WAF — Environment Configuration
# Copy to .env and fill in real values
# ═══════════════════════════════════════════════════════════

# ── Required ──────────────────────────────────────────────
# PostgreSQL database password
POSTGRES_PASSWORD=changeme

# Dashboard login credentials (change these!)
DASHBOARD_USER=admin
DASHBOARD_PASSWORD=CHANGE_THIS_PASSWORD

# JWT secret for dashboard sessions (generate a random string)
# Example: openssl rand -hex 32
JWT_SECRET=generate-a-random-secret-here

# ── Optional ──────────────────────────────────────────────
# Telegram notifications for attacks (leave empty to disable)
TELEGRAM_BOT_TOKEN=
TELEGRAM_OWNER_CHAT_ID=

# AbuseIPDB threat intelligence (free tier: 1000 lookups/day)
# Sign up at https://www.abuseipdb.com/register
ABUSEIPDB_API_KEY=

# Cloudflare tunnel (alternative to exposing port 80/443 directly)
TUNNEL_TOKEN=
