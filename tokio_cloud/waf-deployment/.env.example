# Configuración del WAF y Proxy
# Copia este archivo a .env y ajusta los valores según tu entorno

# Puertos del proxy
NGINX_HTTP_PORT=80
NGINX_HTTPS_PORT=443

# Backend (sitio web detrás del WAF)
BACKEND_URL=http://YOUR_IP_ADDRESS:80
BACKEND_HOST=airesiliencehub.space
BACKEND_PORT=80
BACKEND_SSL=off

# Configuración del servidor
SERVER_NAME=airesiliencehub.space
NGINX_ALWAYS_TLS_REDIRECT=on

# Kafka (para envío de logs)
KAFKA_BOOTSTRAP_SERVERS=localhost:9093
KAFKA_TOPIC_WAF_LOGS=waf-logs

# Log Processor
LOG_BATCH_SIZE=10
LOG_BATCH_TIMEOUT=0.5

# GCP Project (opcional, para Pub/Sub si se usa)
GCP_PROJECT_ID=tactical-unison-417816
