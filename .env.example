# ╔══════════════════════════════════════════════╗
# ║     TokioAI v2.0 — Configuration Template    ║
# ╚══════════════════════════════════════════════╝
#
# Copy to .env and fill in your values:
#   cp .env.example .env
#
# Or run the setup wizard:
#   tokio setup

# ── LLM Provider ──
# Options: anthropic, openai, gemini
LLM_PROVIDER=anthropic

# ── Anthropic (Claude) ──
# Direct API:
#   ANTHROPIC_API_KEY=sk-ant-...
#   CLAUDE_MODEL=claude-sonnet-4-20250514
#
# Via Vertex AI (recommended for Opus 4.6):
#   USE_ANTHROPIC_VERTEX=true
#   CLAUDE_MODEL=claude-opus-4-20250514
#   GCP_PROJECT_ID=your-project
#   GOOGLE_APPLICATION_CREDENTIALS=/path/to/gcp-sa-key.json
#   ANTHROPIC_VERTEX_REGION=us-east5
CLAUDE_MODEL=claude-opus-4-20250514
USE_ANTHROPIC_VERTEX=true
ANTHROPIC_VERTEX_REGION=us-east5
# GCP_PROJECT_ID=
# GOOGLE_APPLICATION_CREDENTIALS=

# ── OpenAI (fallback) ──
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4o

# ── Gemini (fallback + voice transcription) ──
# GEMINI_API_KEY=
# GEMINI_MODEL=gemini-2.0-flash

# ── PostgreSQL ──
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=tokio
POSTGRES_USER=tokio
POSTGRES_PASSWORD=changeme

# ── GCP WAF (optional) ──
# GCP_PROJECT_ID=
# GCP_INSTANCE_NAME=
# GCP_ZONE=us-central1-a

# ── Host Control via SSH (optional) ──
# HOST_SSH_HOST=192.168.1.100
# HOST_SSH_USER=pi
# HOST_SSH_PORT=22
# HOST_SSH_KEY_PATH=~/.ssh/id_rsa
# HOST_CONTROL_ALLOW_RUN=false

# ── Telegram Bot (optional) ──
# Create bot with @BotFather, get token
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_OWNER_ID=         (your Telegram user_id, use /myid to find it)
# TELEGRAM_ALLOWED_IDS=      (comma-separated user_ids)

# ── IoT / Home Assistant (optional) ──
# HOME_ASSISTANT_URL=http://192.168.1.100:8123
# HOME_ASSISTANT_TOKEN=

# ── Router (optional) ──
# ROUTER_HOST=192.168.1.1
# ROUTER_USER=root
# ROUTER_SSH_KEY_PATH=~/.ssh/id_rsa

# ── Cloudflare (optional) ──
# CLOUDFLARE_API_TOKEN=
# CLOUDFLARE_ACCOUNT_ID=
# CLOUDFLARED_TUNNEL_TOKEN=

# ── Hostinger (optional) ──
# HOSTINGER_API_TOKEN=

# ── Server ──
TOKIO_PORT=8000
CORS_ORIGINS=http://localhost:3000,http://localhost:8080

# ── Security ──
# TOKIO_API_KEY=your-secret-key-here
# TOKIO_RATE_LIMIT=60
